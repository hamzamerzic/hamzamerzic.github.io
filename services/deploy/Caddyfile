{
	# Email for Let's Encrypt ACME registration
	email {$ACME_EMAIL:your-email@example.com}
}

import /etc/caddy/mobius.Caddyfile

api.hamzamerzic.info {
	# --- Global settings ---

	# Enable HTTP/2 and HTTP/3 (automatic with Caddy)
	# Max request body: 256MB (removes the old 32MB Cloud Run limit)
	request_body {
		max_size 256MB
	}

	# --- Rate limiting ---
	# 100 requests per minute per IP (matches your old GCP quota)
	rate_limit {
		zone api_zone {
			key {remote_host}
			events 100
			window 1m
		}
	}

	# Legacy redirect for the old personal-site launcher path. The launcher
	# service itself is owned by mobius-os/mobius-os.github.io.
	handle /mobius-launch* {
		redir https://mobius.you/ 308
	}

	# --- CORS ---
	@cors_preflight {
		method OPTIONS
		header Origin {$ALLOWED_ORIGIN:https://hamzamerzic.info}
	}
	handle @cors_preflight {
		header Access-Control-Allow-Origin {$ALLOWED_ORIGIN:https://hamzamerzic.info}
		header Access-Control-Allow-Methods "GET, POST, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type"
		header Access-Control-Max-Age "86400"
		respond 204
	}

	# --- Origin check (replaces API key + referrer restriction) ---
	# Block requests from other websites (but allow no-Origin requests like curl)
	@cross_site_api {
		path /generate_solver /robot_link_info /upload /download/*
		header Origin *
		not header Origin {$ALLOWED_ORIGIN:https://hamzamerzic.info}
	}
	handle @cross_site_api {
		respond "Forbidden" 403
	}

	# --- Routes ---

	handle /generate_solver {
		reverse_proxy ikfast:8080 {
			flush_interval -1
			header_down Access-Control-Allow-Origin {$ALLOWED_ORIGIN:https://hamzamerzic.info}
			header_down -Access-Control-Allow-Credentials
		}
	}

	handle /robot_link_info {
		reverse_proxy robot-link-info:8080 {
			header_down Access-Control-Allow-Origin {$ALLOWED_ORIGIN:https://hamzamerzic.info}
			header_down -Access-Control-Allow-Credentials
		}
	}

	handle /upload {
		reverse_proxy mesh-cleaner:8080 {
			header_down Access-Control-Allow-Origin {$ALLOWED_ORIGIN:https://hamzamerzic.info}
			header_down -Access-Control-Allow-Credentials
		}
	}

	handle /download/* {
		reverse_proxy mesh-cleaner:8080 {
			header_down Access-Control-Allow-Origin {$ALLOWED_ORIGIN:https://hamzamerzic.info}
			header_down -Access-Control-Allow-Credentials
		}
	}

	# Health check
	handle /health {
		respond "OK" 200
	}

	# Catch-all
	handle {
		respond "Not Found" 404
	}

	# --- Logging ---
	log {
		output stdout
		format console
	}
}

mobius.hamzamerzic.info {
	encode gzip
	# Recovery floor: route /recover* to the SEPARATE recoveryd container so it
	# stays reachable when the platform (mobius:8000) is broken/down. Everything
	# else goes to the app. recoveryd is joined to deploy_default.
	handle /recover* {
		reverse_proxy mobius-recoveryd:8001
	}
	handle {
		reverse_proxy mobius:8000
	}
}

:8443 {
	encode gzip
	reverse_proxy mobius-test:8000
	tls internal
}
