# Copy this to .env and fill in your values
# NEVER commit .env to git

# Email for Let's Encrypt certificate registration
ACME_EMAIL=your-email@example.com

# Allowed origin for CORS (your website domain)
ALLOWED_ORIGIN=https://hamzamerzic.info

# Railway OAuth app credentials.
# Register this exact redirect URI in Railway:
# https://mobius.page/railway/callback
RAILWAY_CLIENT_ID=
RAILWAY_CLIENT_SECRET=
RAILWAY_REDIRECT_URI=https://mobius.page/railway/callback
RAILWAY_OAUTH_SCOPES=openid email profile offline_access workspace:member
RAILWAY_TEMPLATE_URL=https://railway.com/deploy/xVMuX9?referralCode=cERpKq&utm_medium=integration&utm_source=template&utm_campaign=generic
RAILWAY_TEMPLATE_CODE=xVMuX9
RAILWAY_REFERRAL_CODE=cERpKq

# Google OAuth for Mobius Launch sign-in.
# Register this exact redirect URI in Google Cloud:
# https://mobius.page/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://mobius.page/auth/google/callback

# Keep true for local/prototype testing; set false once Google sign-in is live.
ALLOW_PROTOTYPE_EMAIL_LOGIN=true

# Mobius instance storage shown in the launcher UI.
MOBIUS_DEFAULT_VOLUME_SIZE_GB=2
MOBIUS_VOLUME_SIZE_OPTIONS_GB=2,5,10,20
