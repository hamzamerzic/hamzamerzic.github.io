# Copy this to .env and fill in your values
# NEVER commit .env to git

# Email for Let's Encrypt certificate registration
ACME_EMAIL=your-email@example.com

# Allowed origin for CORS (your website domain)
ALLOWED_ORIGIN=https://hamzamerzic.info

# Org-owned Mobius Launch Caddy fragment imported by the shared VPS edge.
MOBIUS_EDGE_FRAGMENT=../../../mobius-os/mobius-os.github.io/services/deploy/mobius.Caddyfile
